# IndustrialXPL-Forge .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# IXF runtime artifacts
.tmp/
*.log
industrialxpl.log

# Compiled native exploits (C/C++/Go binaries)
industrialxpl/modules/cve/_native/*.exe
industrialxpl/modules/cve/_native/*.bin
industrialxpl/modules/cve/_native/*.out
industrialxpl/modules/cve/_native/*.o

# Reports / outputs
*.json.report
*.html.report

# Secrets / credentials
.env
*.pem
*.key
*.p12
*.pfx

# IDE
.cursor/
.vscode/
.idea/
*.swp

# Environment files — never commit real secrets
.env
.env.*
*.env
.env.server
# Allow the example template (no real values)
!.env.example


# Local-only: packaging, CI/CD and contributor metadata kept out of the public tree
.github/workflows/
.github/dependabot.yml
.github/CODEOWNERS
CODEOWNERS
.github/FUNDING.yml
FUNDING.yml
.github/ISSUE_TEMPLATE*
.github/PULL_REQUEST_TEMPLATE*
CONTRIBUTING*
CONTRIBUTORS*
.travis.yml
.gitlab-ci.yml
azure-pipelines.yml
Jenkinsfile
.circleci/
appveyor.yml
pyproject.toml
setup.py
setup.cfg
MANIFEST.in
tox.ini
.pypirc
scripts/publish*
scripts/release*
packages/**/build.sh
packages/**/build.ps1
*.example
*.sample
