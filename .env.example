# IXF local environment — copy to .env and fill values
# .env is gitignored and MUST NEVER be committed

# PyPI API token for local manual publish (pip install industrialxpl-forge)
# Generate at: https://pypi.org/manage/account/token/
# Scope: project "industrialxpl-forge"
PYPI_API_TOKEN=pypi-REPLACE_WITH_YOUR_TOKEN

# GitHub token (if needed for gh CLI automation)
# GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
